From dc567430ed15dc0e353753cc336bc928664ac85c Mon Sep 17 00:00:00 2001
From: IPB_srvr <ipastore@unizar.es>
Date: Fri, 6 Mar 2026 13:14:02 +0100
Subject: [PATCH] Fix sift training

---
 gluefactory/models/extractors/sift.py    | 5 +++--
 gluefactory/models/matchers/lightglue.py | 1 +
 2 files changed, 4 insertions(+), 2 deletions(-)

diff --git a/gluefactory/models/extractors/sift.py b/gluefactory/models/extractors/sift.py
index 9f07725..bde981f 100644
--- a/gluefactory/models/extractors/sift.py
+++ b/gluefactory/models/extractors/sift.py
@@ -191,7 +191,7 @@ class SIFT(BaseModel):
                 pred = {k: v[indices] for k, v in pred.items()}
 
         if self.conf.force_num_keypoints:
-            num_points = min(self.conf.max_num_keypoints, len(pred["keypoints"]))
+            num_points = max(self.conf.max_num_keypoints, len(pred["keypoints"]))
             pred["keypoints"] = pad_to_length(
                 pred["keypoints"],
                 num_points,
@@ -205,7 +205,7 @@ class SIFT(BaseModel):
                 pred["descriptors"], num_points, -2, mode="zeros"
             )
             if pred["keypoint_scores"] is not None:
-                scores = pad_to_length(
+                pred["keypoint_scores"] = pad_to_length(
                     pred["keypoint_scores"], num_points, -1, mode="zeros"
                 )
         return pred
@@ -222,6 +222,7 @@ class SIFT(BaseModel):
             if "image_size" in data.keys():
                 # avoid extracting points in padded areas
                 w, h = data["image_size"][k]
+                w, h = int(w), int(h)
                 img = img[:, :h, :w]
             p = self.extract_single_image(img)
             pred.append(p)
diff --git a/gluefactory/models/matchers/lightglue.py b/gluefactory/models/matchers/lightglue.py
index eca7243..53bbc48 100644
--- a/gluefactory/models/matchers/lightglue.py
+++ b/gluefactory/models/matchers/lightglue.py
@@ -4,6 +4,7 @@ from typing import Callable, List, Optional
 
 import numpy as np
 import torch
+import torch.utils.checkpoint
 import torch.nn.functional as F
 from omegaconf import OmegaConf
 from torch import nn
